# 1. 보안 설정 파일 (절대 깃허브에 올라가면 안 됨!)
.env

# 2. 파이썬 가상환경 폴더
venv/
.venv/
env/
ENV/

# 3. 파이썬 캐시 파일 (실행 시 자동 생성되는 찌꺼기들)
__pycache__/
*.py[cod]
*$py.class

# 4. 로그 파일 (도커 설정에서 logs 폴더를 매핑했으므로 꼭 숨겨야 함)
logs/
*.log

# 5. IDE(에디터) 설정 파일
.idea/
.vscode/
*.swp

# 6. 기타 테스트/빌드 찌꺼기
.pytest_cache/
.coverage

# 7. 테스트 커버리지 리포트
htmlcov/